# GCP (used locally; Cloud Run uses Workload Identity — no key file needed in prod)
# Linux/macOS: /path/to/service-account-key.json
# Windows:     C:\path\to\service-account-key.json  (forward slashes also work: C:/path/to/...)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
VERTEX_AI_PROJECT=my-gcp-project
VERTEX_AI_LOCATION=us-central1

# Spanner — source data (semantic layer + curriculum)
SPANNER_SOURCE_PROJECT=my-gcp-project
SPANNER_SOURCE_INSTANCE=my-instance
SPANNER_SOURCE_DATABASE=source-database

# Spanner — eval data (questions, runs, results)
SPANNER_EVAL_PROJECT=my-gcp-project
SPANNER_EVAL_INSTANCE=my-instance
SPANNER_EVAL_DATABASE=eval-database

# ADK (eval runner only)
# Python module path to your agent (dotted, not a file path).
# Example: if your agent is at my_agent/agent.py, use: my_agent.agent
# The runner must be launched from the directory where this module is importable.
ADK_AGENT_MODULE=my_agent.agent
ADK_HOST=localhost
ADK_PORT=8080
# Linux/macOS: /path/to/agent/repo
# Windows:     C:\path\to\agent\repo  (forward slashes also work: C:/path/to/agent/repo)
AGENT_REPO_PATH=/path/to/agent/repo

# ADK response field mapping
# The eval system extracts SQL, route, and the full response text from the JSON
# your agent returns. Set these to match your agent's actual field names.
# Each setting accepts a comma-separated list — the first non-empty field wins.
# Run `curl -s http://localhost:8080/run -d '{"message":"test"}' | python -m json.tool`
# against your agent to see the real response shape, then update these values.
ADK_FIELD_SQL=sql_generated,sql,query
ADK_FIELD_ROUTE=route
ADK_FIELD_RESPONSE=response,output,text
# The HTTP path the ADK api_server exposes for NLQ requests (default: /run)
ADK_RUN_PATH=/run

# Models
EMBEDDING_MODEL=text-embedding-004
JUDGE_MODEL=gemini-2.0-flash

# Thresholds
LEAKAGE_EMBEDDING_THRESHOLD=0.85
JUDGE_CONFIDENCE_THRESHOLD=0.75

# Run settings
RUN_CONCURRENCY=4
SEEDER_ACTIVE_COUNT=7
SEEDER_MONITORING_COUNT=2
HEARTBEAT_INTERVAL_SECONDS=60
HEARTBEAT_STALE_MINUTES=5

# Flask
FLASK_ENV=development
FLASK_PORT=5000
